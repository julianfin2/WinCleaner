{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Win清理工具",
  "version": "0.1.1",
  "mainBinaryName": "Win清理工具",
  "identifier": "top.volan.win-cleaner",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Windows 清理工具",
        "width": 1150,
        "height": 750
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    },
    "icon": [
      "icons/icon.ico"
    ]
  }
}
